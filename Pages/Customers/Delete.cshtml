@page "{id:int}"
@model smart_customer_analytics_crm.Pages.Customers.DeleteModel
@* @model webapp.Pages.customers.DeleteModel *@
@{
    ViewData["Title"] = "Delete Customer";
}

<h1>@ViewData["Title"]</h1>

<div class="mx-auto rounded border p-4" style="width: 400px;">
    <h1>@ViewData["Title"]</h1>
    <p>Are you sure you want to delete this customer?</p>
    <p>CustId: @Model.Id</p>
    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Customers/Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>