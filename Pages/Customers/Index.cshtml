@page
@model SmartCRM.Pages.Customers.IndexModel

<h2 class="mb-3">Customers</h2>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@Model.Search"
               class="form-control" placeholder="Search customer..." />
        <button class="btn btn-primary">Search</button>
    </div>
</form>

<a href="/Customers/Create" class="btn btn-success mb-3">+ Add Customer</a>

<table class="table table-striped table-hover shadow">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model.Customers)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Name</td>
                <td>@c.Email</td>
                <td>@c.Phone</td>
                <td>
                    <a href="/Customers/Edit?id=@c.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Customers/Delete?id=@c.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>